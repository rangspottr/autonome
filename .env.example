# Server
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/autonome
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# Encryption (for webhook API keys stored at rest)
# Must be a random, secret string. Falls back to JWT_SECRET if not set.
ENCRYPTION_KEY=your-encryption-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Client
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001/api

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@autonome.app

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# Webhooks
# (webhook API keys are per-workspace, stored in DB — use /api/webhooks/generate-key to create one)

# Development mode — bypass Stripe subscription check (never enable in production)
BYPASS_SUBSCRIPTION=false
