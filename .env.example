# ─── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/autonome

# ─── Authentication ───────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# Encryption key for webhook API keys stored at rest
# Must be a random, secret string. Falls back to JWT_SECRET if not set.
ENCRYPTION_KEY=your-encryption-key-here

# ─── Stripe Billing ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ─── Client URL ──────────────────────────────────────────
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001/api

# ─── Email (SMTP) — optional ─────────────────────────────
# If not configured, emails are auto-verified and logged to console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@autonome.app

# ─── SMS (Twilio) — optional ─────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── AI ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-20250514

# ─── Development ─────────────────────────────────────────
# WARNING: BYPASS_SUBSCRIPTION=true must NEVER be used in production.
# It disables Stripe subscription checks and auto-seeds a dev user.
BYPASS_SUBSCRIPTION=false

# ─── Cleanup ─────────────────────────────────────────────
# How often (in hours) to purge expired tokens. Default: 6
CLEANUP_INTERVAL_HOURS=6
